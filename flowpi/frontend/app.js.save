const API = "http://192.168.137.168:5000";

async function loadStatus() {
    try {
        console.log("STATUS:", data);    const res = await fetch(`${API}/status`);
    const data = await res.json();

    console.log("STATUS:", data);

    document.getElementById("tapStatus").innerText =
        data.tap_open ? "🟢 TAP OPEN" : "🔴 TAP CLOSED";

    document.getElementById("activeUser").innerText =
        "User " + data.user;
}

async function loadUsers() {
    const res = await fetch(`${API}/users`);
    const users = await res.json();

    const container = document.getElementById("users");
    container.innerHTML = "";

    users.forEach(u => {
        const btn = document.createElement("button");
        btn.className = "user-btn";
        btn.innerText = u.name;

        btn.onclick = async () => {
            await fetch(`${API}/set_user/${u.id}`);
            loadStatus();
            loadTotals();
        };

        container.appendChild(btn);
    });
}

async function loadTotals() {
    const res = await fetch(`${API}/totals`);
    const data = await res.json();

    const container = document.getElementById("totals");
    container.innerHTML = "";

    data.forEach(u => {
        const div = document.createElement("div");
        div.innerHTML = `
            <b>${u.name}</b>: ${u.ml.toFixed(1)} ml
        `;
        container.appendChild(div);
    });
}

function refresh() {
    loadStatus();
    loadTotals();
}

setInterval(refresh, 2000);

loadUsers();
refresh();
