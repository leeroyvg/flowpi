FLOWPI_ENV=production
FLOWPI_ENABLE_GPIO=false
FLOWPI_HOST=0.0.0.0
FLOWPI_PORT=5000
FLOWPI_FRONTEND_PORT=8000
FLOWPI_ALLOWED_ORIGINS=http://localhost:8000
FLOWPI_LOG_LEVEL=INFO
FLOWPI_TRUST_PROXY=false
FLOWPI_MAX_REQUEST_BYTES=65536
FLOWPI_ML_PER_PULSE=2.25
FLOWPI_IDLE_TIMEOUT_SEC=5
FLOWPI_DB_PATH=/app/data/flow.db
FLOWPI_ADMIN_USERNAME=admin
FLOWPI_ADMIN_PASSWORD=change-me
FLOWPI_ADMIN_SESSION_TTL_SEC=43200
